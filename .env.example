# kx402 configuration — copy to .env (or pass with --config-file <file>) and fill in.

# Path to the rusty-kaspa v2.0.0 nodejs WASM SDK entry. Get it with: npm run fetch-sdk
# (npm's `kaspa-wasm` is the wrong ABI — you must use the official v2.0.0 SDK release asset.)
KASPA_X402_KASPA_WASM_MODULE=./vendor/kaspa-wasm32-sdk/nodejs/kaspa/kaspa.js

# Funding key. Keep keys in 0600 files, never in git. Either:
#   wallet-key:/absolute/path/to/wallet.key   (a file holding a 64-hex private key)  -- recommended
#   or a raw 64-hex private key string
KASPA_X402_FUNDING_WALLET=wallet-key:/absolute/path/to/wallet.key

# Network: kaspa:mainnet or kaspa:testnet-10
KASPA_X402_NETWORK=kaspa:testnet-10

# Optional: pin a wRPC node URL. If unset, a public PNN node is resolved automatically.
# KASPA_X402_RPC_URL=

# Optional: where to keep local wallet state (defaults to ./.kx402)
# KASPA_X402_DATA_DIR=
